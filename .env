# ================================================================
# KATM Platform — переменные окружения для локальной разработки
# ================================================================

# -------------------------------------------------------
# Oracle Database (все сервисы с JDBC)
# -------------------------------------------------------
DB_HOST=exa-scan.katm.local
DB_PORT=1521
DB_SERVICE=exkrdb
DB_USER=datas
DB_PASSWORD=DATAS

# -------------------------------------------------------
# Redis (katm-client)
# -------------------------------------------------------
REDIS_HOST=localhost
REDIS_PASSWORD=katm_redis_dev

# -------------------------------------------------------
# Kafka
# KAFKA_SERVERS         — используется в docker-compose + большинстве application.yml
# KAFKA_BOOTSTRAP_SERVERS — используется в katm-notification/application.yml
# -------------------------------------------------------
KAFKA_SERVERS=localhost:9092
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# -------------------------------------------------------
# Keycloak
# -------------------------------------------------------
KEYCLOAK_URL=http://localhost:8180
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# -------------------------------------------------------
# MinIO / S3
# -------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# -------------------------------------------------------
# Zipkin (трассировка)
# -------------------------------------------------------
ZIPKIN_URL=http://localhost:9411

# -------------------------------------------------------
# Grafana
# -------------------------------------------------------
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# -------------------------------------------------------
# МИП сервис (katm-client)
# -------------------------------------------------------
MIP_SERVICE_URL=http://localhost:8095

# -------------------------------------------------------
# SMTP (katm-notification)
# SMTP_PASSWORD — читается в application.yml
# SMTP_PASS     — читается в docker-compose.yml
# -------------------------------------------------------
