                            <wsdlFiles><wsdlFile>GetTaxInfobyPin.wsdl</wsdlFile></wsdlFiles>
                            <packageName>uz.katm.mip.ws.tax</packageName>
                            <sourceDestDir>${project.build.directory}/generated-sources/jaxws</sourceDestDir>
                            <keep>true</keep>
                        </configuration>
                    </execution>
                    <execution>
                        <id>wsimport-tin</id>
