                        <configuration>
                            <wsdlDirectory>${project.basedir}/src/main/resources/wsdl</wsdlDirectory>
                            <wsdlFiles><wsdlFile>GetLegalInfoBR.wsdl</wsdlFile></wsdlFiles>
                            <packageName>uz.katm.mip.ws.legalbr</packageName>
                            <sourceDestDir>${project.build.directory}/generated-sources/jaxws</sourceDestDir>
                            <keep>true</keep>
                        </configuration>
                    </execution>
                    <execution>
                        <id>wsimport-inps</id>
                        <goals><goal>wsimport</goal></goals>
                        <configuration>
                            <wsdlDirectory>${project.basedir}/src/main/resources/wsdl</wsdlDirectory>
                            <wsdlFiles><wsdlFile>InpsBalance.wsdl</wsdlFile></wsdlFiles>
                            <packageName>uz.katm.mip.ws.inps</packageName>
